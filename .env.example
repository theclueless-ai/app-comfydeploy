# ComfyDeploy API Configuration
COMFYDEPLOY_API_KEY=your_api_key_here
COMFYDEPLOY_SERVER_URL=https://www.comfydeploy.com/api

# Deployment ID for AI Fashion Commerce workflow
COMFYDEPLOY_DEPLOYMENT_ID=your_deployment_id_here

# Deployment ID for Vellum 2.1 workflow
COMFYDEPLOY_VELLUM_DEPLOYMENT_ID=964639a7-7161-4785-bb85-dda5632e39c5

# Deployment ID for AI Talk workflow (talking head video generation)
COMFYDEPLOY_AITALK_DEPLOYMENT_ID=718a904b-b8a8-4af1-8e10-af6fd752c4b0

# Webhook Configuration (your app's public URL for receiving results)
WEBHOOK_BASE_URL=http://localhost:3000

# Optional: Secret for webhook validation
WEBHOOK_SECRET=your_webhook_secret_here

# RunPod Serverless Configuration
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id_here
BASE_URL_RUNPOD=https://api.runpod.ai/v2

# RunPod Vellum 2.0 Legacy Endpoint (falls back to RUNPOD_ENDPOINT_ID if not set)
RUNPOD_VELLUM20_ENDPOINT_ID=your_runpod_vellum20_endpoint_id_here

# RunPod AI Talk Endpoint (for talking head video generation)
RUNPOD_AITALK_ENDPOINT_ID=your_runpod_aitalk_endpoint_id_here

# ElevenLabs API Configuration (for voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret for authentication
JWT_SECRET=your-secure-jwt-secret-here

# Admin API Key for user creation (use in Postman)
ADMIN_API_KEY=your-admin-api-key-here

# Local ComfyUI Configuration (for Avatar Generator)
COMFYUI_LOCAL_URL=http://127.0.0.1:8188

# AWS S3 Configuration (for persistent image storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-bucket-name
